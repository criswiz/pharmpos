[debug] [2026-06-04T13:18:12.516Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/pharmpos-bef59/rulesets {"name":"projects/pharmpos-bef59/rulesets/99bfb7fc-e873-4bc5-9a1e-4a8cadb7b905","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function rolePath() {\n      return /databases/$(database)/documents/roles/$(request.auth.uid);\n    }\n\n    function role() {\n      return signedIn() && exists(rolePath()) ? get(rolePath()).data.role : null;\n    }\n\n    function hasAnyRole(roles) {\n      return signedIn() && role() in roles;\n    }\n\n    function isOwner() {\n      return hasAnyRole(['OWNER']);\n    }\n\n    function isSysAdmin() {\n      return hasAnyRole(['SYS_ADMIN']);\n    }\n\n    function isManager() {\n      return hasAnyRole(['OWNER', 'STORE_MANAGER', 'SYS_ADMIN']);\n    }\n\n    function isWholesale() {\n      return hasAnyRole(['OWNER', 'STORE_MANAGER', 'WHOLESALE_STAFF', 'SYS_ADMIN']);\n    }\n\n    match /auditLogs/{logId} {\n      allow read: if hasAnyRole(['OWNER', 'STORE_MANAGER', 'SYS_ADMIN']);\n      allow create: if signedIn();\n      allow update, delete: if false;\n    }\n\n    match /users/{uid} {\n      allow read: if isSysAdmin() || isOwner() || request.auth.uid == uid;\n      allow create: if isSysAdmin() || isOwner();\n      allow update: if isSysAdmin() || isOwner()\n        || (request.auth.uid == uid\n          && request.resource.data.diff(resource.data).affectedKeys()\n            .hasOnly(['last_login', 'failed_attempts']));\n      allow delete: if false;\n    }\n\n    match /roles/{uid} {\n      allow read: if signedIn() && (request.auth.uid == uid || isSysAdmin() || isOwner());\n      allow write: if isSysAdmin() || isOwner();\n      allow delete: if false;\n    }\n\n    match /settings/{settingKey} {\n      allow read: if signedIn();\n      allow write: if isSysAdmin() || isOwner();\n    }\n\n    match /products/{productId} {\n      allow read: if signedIn();\n      allow write: if isManager();\n      allow delete: if false;\n    }\n\n    match /batches/{batchId} {\n      allow read: if signedIn();\n      allow write: if isManager();\n      allow delete: if false;\n    }\n\n    match /batchBarcodes/{barcodeId} {\n      allow read: if signedIn();\n      allow write: if isManager();\n      allow delete: if false;\n    }\n\n    match /stockTransactions/{txId} {\n      allow read: if signedIn();\n      allow create: if signedIn();\n      allow update, delete: if false;\n    }\n\n    match /saleTransactions/{saleId} {\n      allow read: if signedIn();\n      allow create: if hasAnyRole(['OWNER', 'STORE_MANAGER', 'RETAIL_STAFF', 'WHOLESALE_STAFF', 'SYS_ADMIN']);\n      allow update: if isManager();\n      allow delete: if false;\n    }\n\n    match /saleLineItems/{itemId} {\n      allow read: if signedIn();\n      allow create: if hasAnyRole(['OWNER', 'STORE_MANAGER', 'RETAIL_STAFF', 'WHOLESALE_STAFF', 'SYS_ADMIN']);\n      allow update, delete: if false;\n    }\n\n    match /customers/{customerId} {\n      allow read: if signedIn();\n      allow write: if isWholesale();\n      allow delete: if false;\n    }\n\n    match /suppliers/{supplierId} {\n      allow read: if signedIn();\n      allow write: if isManager();\n      allow delete: if false;\n    }\n\n    match /purchaseOrders/{poId} {\n      allow read: if signedIn();\n      allow write: if isManager();\n      allow delete: if false;\n    }\n\n    match /goodsReceivedNotes/{grnId} {\n      allow read: if signedIn();\n      allow write: if isManager();\n      allow delete: if false;\n    }\n\n    match /documents/{docId} {\n      allow read, create: if isWholesale();\n      allow update: if isWholesale()\n        && !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])\n          && request.resource.data.status == 'void'\n          && !isManager());\n      allow delete: if false;\n    }\n\n    match /counters/{counterId} {\n      allow read: if signedIn();\n      allow write: if isWholesale();\n      allow delete: if false;\n    }\n\n    match /reorderAlerts/{alertId} {\n      allow read: if signedIn();\n      allow write: if isManager();\n      allow delete: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-04T13:18:12.604223Z","metadata":{"services":["cloud.firestore"]}}
